{
  "manifest_version": 3,
  "name": "Zenrex Assistant",
  "version": "0.1.0",
  "description": "Allow Zenrex AI to control your Chrome browser on your behalf — log into your accounts, manage social media, test sites, and more, all in front of your eyes.",
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zenrex Assistant",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
