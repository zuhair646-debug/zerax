# ──────────────────────────────────────────
# Zitex Backend — Environment Variables Template
# ──────────────────────────────────────────
# Copy this to `.env` locally, and add each variable to your Railway/Render
# production environment in the dashboard. NEVER commit real keys to git.

# ──────────────────────────────────────────
# REQUIRED — Database
# ──────────────────────────────────────────
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net
DB_NAME=zitex_production

# ──────────────────────────────────────────
# REQUIRED — Auth
# ──────────────────────────────────────────
# Minimum 32 characters, random. Use: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# CORS — list your Vercel frontend URL(s), comma-separated
CORS_ORIGINS=https://zitex.vercel.app,https://www.your-domain.com

# ──────────────────────────────────────────
# REQUIRED — AI Keys (at LEAST ONE must be set)
# ──────────────────────────────────────────
# PREFERRED: Your own OpenAI API key — used for FreeBuild, Image Expert prompts,
# Video Director prompts, GPT-Image-1, and Sora 2. Direct billing to your OpenAI
# account (platform.openai.com/settings/organization/billing).
# Get from: https://platform.openai.com/api-keys
OPENAI_DIRECT_KEY=sk-proj-...

# FALLBACK: Emergent Universal LLM Key — use if you don't have an OpenAI key.
# Automatically routes to Claude / OpenAI / Gemini through one key.
# Get from: https://platform.emergent.sh → Profile → Universal Key
EMERGENT_LLM_KEY=sk-emergent-...

# ──────────────────────────────────────────
# REQUIRED for voice features (Ambient AI Agent, video narration)
# ──────────────────────────────────────────
# ElevenLabs — used for Saudi voices (Mohammed Almansari + Layan)
# Get from: https://elevenlabs.io → Profile → API keys
ELEVENLABS_API_KEY=sk_...

# ──────────────────────────────────────────
# REQUIRED for payments (subscriptions, credit packs)
# ──────────────────────────────────────────
# Stripe — starts with sk_test_ for dev, sk_live_ for production
# Get from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ──────────────────────────────────────────
# OPTIONAL — Public app URL (Stripe redirects, share links)
# ──────────────────────────────────────────
PUBLIC_APP_URL=https://zitex.vercel.app
